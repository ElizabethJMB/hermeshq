# HermesHQ Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Concurrency — max concurrent task runner processes (default: 8)
# Each process uses ~50MB RAM. For sizing: available_RAM_MB / 60
CONCURRENCY_SEMAPHORE=8

# Database
POSTGRES_DB=hermeshq
POSTGRES_USER=hermeshq
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# Backend
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Encryption key for secrets at rest (independent from JWT_SECRET so either
# can rotate without breaking the other). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Max seconds a single task may run before being killed (default: 3600)
TASK_TIMEOUT_SECONDS=3600
AUTH_MODE=local
BACKEND_PORT=8000
FRONTEND_PORT=3420
